// ============================================================
// nextflow.config
// Profiles: hellbender (SLURM), local (testing)
// ============================================================

params {
    // ── I/O ──────────────────────────────────────────────────
    input_dir   = null          // path to dir containing sample subdirs
    outdir      = "./results"
    mode        = "scrna"       // "scrna" | "spatial"

    // ── QC ───────────────────────────────────────────────────
    qc_mode             = "adaptive"   // "fixed" | "adaptive" | "both"
    // Fixed thresholds (used when qc_mode = "fixed" or "both")
    min_genes           = 200
    max_genes           = 6000
    max_pct_mt          = 20
    min_cells           = 3
    // Adaptive thresholds (MAD-based; used when qc_mode = "adaptive" or "both")
    mad_nmads           = 3     // number of MADs from median

    // ── Clustering ───────────────────────────────────────────
    n_pcs               = 30
    resolution          = 0.5
    n_neighbors         = 20

    // ── Annotation ───────────────────────────────────────────
    annotate            = true
    annotation_method   = "both"        // "celltypist" | "manual" | "both"
    celltypist_model    = "Immune_All_Low.pkl"  // any model from celltypist model zoo
    marker_genes_file   = null          // path to JSON file for manual annotation

    // ── Resources ────────────────────────────────────────────
    max_cpus   = 32
    max_memory = '128.GB'
    max_time   = '24.h'
}

// ── Process defaults ─────────────────────────────────────────
process {
    errorStrategy = { task.exitStatus in [130, 137, 140] ? 'retry' : 'terminate' }
    maxRetries    = 2

    withLabel: 'low' {
        cpus   = 2
        memory = '8.GB'
        time   = '2.h'
    }
    withLabel: 'medium' {
        cpus   = 8
        memory = '32.GB'
        time   = '6.h'
    }
    withLabel: 'high' {
        cpus   = 16
        memory = '64.GB'
        time   = '12.h'
    }
    withLabel: 'gpu' {
        cpus   = 4
        memory = '32.GB'
        time   = '6.h'
    }
}

// ── Profiles ─────────────────────────────────────────────────
profiles {

    // ── Hellbender HPC (SLURM + conda) ───────────────────────
    hellbender {
        process.executor       = 'slurm'
        process.queue          = 'general'     // adjust to your partition
        process.clusterOptions = '--account=your_account'  // ← set your SLURM account

        conda.enabled          = true
        conda.useMamba         = true          // faster solves; falls back to conda
        conda.cacheDir         = "$HOME/.nextflow/conda_cache"

        // Request scratch storage for work dir
        workDir = "/scratch/${System.getenv('USER')}/nf_work"

        process {
            withLabel: 'low' {
                queue  = 'general'
                cpus   = 2
                memory = '8.GB'
                time   = '2.h'
            }
            withLabel: 'medium' {
                queue  = 'general'
                cpus   = 8
                memory = '32.GB'
                time   = '6.h'
            }
            withLabel: 'high' {
                queue  = 'general'
                cpus   = 16
                memory = '64.GB'
                time   = '12.h'
            }
            withLabel: 'gpu' {
                queue          = 'gpu'          // adjust if GPU partition has different name
                cpus           = 4
                memory         = '32.GB'
                time           = '6.h'
                clusterOptions = '--gres=gpu:1'
            }
        }

        // Increase submitted job polling interval to be polite to SLURM
        executor {
            queueSize         = 50
            pollInterval      = '30 sec'
            submitRateLimit   = '10 / 1 min'
        }
    }

    // ── Local (laptop / interactive node testing) ─────────────
    local {
        process.executor = 'local'
        conda.enabled    = true
        conda.useMamba   = true
        conda.cacheDir   = "$HOME/.nextflow/conda_cache"
        workDir          = "./work"

        process {
            withLabel: 'low'    { cpus = 2;  memory = '4.GB'  }
            withLabel: 'medium' { cpus = 4;  memory = '16.GB' }
            withLabel: 'high'   { cpus = 8;  memory = '32.GB' }
        }
    }
}

// ── Execution reports ─────────────────────────────────────────
def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm')
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline_${trace_timestamp}.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report_${trace_timestamp}.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace_${trace_timestamp}.tsv"
}

// ── Manifest ─────────────────────────────────────────────────
manifest {
    name            = 'scrna-spatial-pipeline'
    author          = 'Your Name'
    description     = 'Parallel Seurat + Scanpy preprocessing, clustering, annotation, and benchmarking'
    version         = '1.0.0'
    nextflowVersion = '>=23.04.0'
    mainScript      = 'main.nf'
}
